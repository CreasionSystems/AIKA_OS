{
  "name": "aika-os",
  "version": "0.0.0",
  "private": true,
  "description": "AI統合ワークステーション (Electron + React + TypeScript)",
  "type": "module",
  "main": "dist/main/index.cjs",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "vitest run src/renderer/components/a11y.test.tsx",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/build.mjs",
    "provision:electron": "node scripts/fetch-electron.mjs",
    "start": "npm run build && electron .",
    "e2e": "npm run build && xvfb-run -a playwright test"
  },
  "dependencies": {
    "i18next": "^23.16.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.7.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.10.2",
    "electron": "^33.2.1",
    "esbuild": "^0.24.2",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
