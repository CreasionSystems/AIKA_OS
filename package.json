{
  "name": "aika-os",
  "version": "0.0.0",
  "private": true,
  "description": "AI統合ワークステーション (Electron + React + TypeScript)",
  "type": "module",
  "main": "dist/main/index.cjs",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/build.mjs",
    "provision:electron": "node scripts/fetch-electron.mjs",
    "start": "npm run build && electron .",
    "e2e": "npm run build && xvfb-run -a playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.20.0",
    "electron": "^33.2.1",
    "esbuild": "^0.24.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
